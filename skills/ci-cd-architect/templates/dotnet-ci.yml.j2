# dotnet-ci.yml — .NET CI Pipeline (Language Variant)
#
# Template for ci-cd-architect standard v2.0.0, Rule 20.
# For projects with language: dotnet in the configuration contract.
# Sequence: restore → format check → build → test + coverage → pack (on tag) → publish (on tag).
#
# Substitution variables (from .github/ci-cd-config.yaml):
#   {{ project }}          — project slug
  #   {{ dotnet_version }}    — .NET SDK version, e.g. "8.0.x" (10.0.x is preview, 8.0.x is current LTS)
#   {{ dotnet_solution }}   — path to .sln file, e.g. "src/MyApp.sln"
#   {{ use_semgrep }}       — true/false (adds semgrep job if true)
#   {{ python_version }}    — Python version for auxiliary scripts

name: .NET CI — Quality Gate

on:
  push:
    branches: [main, develop]
    tags: ["v*"]
    paths:
      - "src/**"
      - "tests/**"
  pull_request:
    branches: [main]
    paths:
      - "src/**"
      - "tests/**"
  workflow_dispatch:

concurrency:
  group: dotnet-ci-${{ github.ref }}
  cancel-in-progress: true

env:
  FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: true

jobs:
  # ──────────────────────────────────────────────────────────
  # Job 1: Build, Test & Coverage
  # ──────────────────────────────────────────────────────────
  dotnet-build-test:
    name: Build, Test & Coverage
    runs-on: ubuntu-latest
    permissions:
      checks: write
      pull-requests: write
      contents: read

    steps:
      - uses: actions/checkout@df4cb1c069e1874edd31b4311f1884172cec0e10  # v6
        with:
          fetch-depth: 0
          persist-credentials: false

      - name: Setup .NET
        uses: actions/setup-dotnet@9a946fdbd5fb07b82b2f5a4466058b876ab72bb2  # v5
        with:
          dotnet-version: "{{ dotnet_version }}"

      - name: Print .NET environment info
        run: dotnet --info

      - name: Cache NuGet packages
        uses: actions/cache@27d5ce7f107fe9357f9df03efb73ab90386fccae  # v5
        with:
          path: ~/.nuget/packages
          key: nuget-${{ hashFiles('**/*.csproj', '**/Directory.Packages.props', '**/Directory.Build.props') }}
          restore-keys: nuget-

      - name: Restore dependencies
        run: dotnet restore {{ dotnet_solution }}

      - name: Verify Code Formatting
        run: dotnet format {{ dotnet_solution }} --no-restore --verify-no-changes

      - name: Build (with analyzers)
        id: build
        run: |
          dotnet build {{ dotnet_solution }} --no-restore --configuration Release

      - name: Test & collect coverage
        run: |
          dotnet test {{ dotnet_solution }} --no-build --configuration Release \
            --collect:"XPlat Code Coverage" \
            --results-directory ./TestResults \
            --logger trx

      - name: Install ReportGenerator
        if: always()
        run: dotnet tool install --global dotnet-reportgenerator-globaltool --version 5.3.0 || true

      - name: Generate coverage report
        id: coverage
        if: always()
        continue-on-error: true
        run: |
          reportgenerator \
            -reports:"**/TestResults/**/coverage.cobertura.xml" \
            -targetdir:"coverage-report" \
            -reporttypes:"Html;MarkdownSummaryGithub;Badges;JsonSummary" \
            -assemblyfilters:"+{{ project | capitalize }}.*" \
            -verbosity:Warning

      - name: Publish test results to PR
        if: always() && hashFiles('TestResults/**/*.trx') != ''
        uses: dorny/test-reporter@1cc81a5edf733718d4850df304aaa21c05cd7280  # v3
        with:
          name: Unit Tests
          path: "TestResults/**/*.trx"
          reporter: dotnet-trx

      - name: Upload coverage & test artifacts
        if: always()
        uses: actions/upload-artifact@043fb46d1a93c77aae656e7c1c64a875d1fc6a0a  # v7
        with:
          name: coverage-${{ github.run_id }}
          path: |
            TestResults/
            coverage-report/
          retention-days: 14

      - name: Post coverage summary to PR
        if: github.event_name == 'pull_request' && always() && hashFiles('coverage-report/SummaryGithub.md') != ''
        uses: marocchino/sticky-pull-request-comment@0ea0beb66eb9baf113663a64ec522f60e49231c0  # v3.0.4
        with:
          path: coverage-report/SummaryGithub.md

  # ──────────────────────────────────────────────────────────
  # Job 2: Pack & Publish (tag only)
  # ──────────────────────────────────────────────────────────
  pack-publish:
    name: Pack & Publish
    needs: dotnet-build-test
    if: startsWith(github.ref, 'refs/tags/v')
    runs-on: ubuntu-latest
    permissions:
      contents: write
      packages: write

    steps:
      - uses: actions/checkout@df4cb1c069e1874edd31b4311f1884172cec0e10  # v6
        with:
          persist-credentials: false

      - name: Setup .NET
        uses: actions/setup-dotnet@9a946fdbd5fb07b82b2f5a4466058b876ab72bb2  # v5
        with:
          dotnet-version: "{{ dotnet_version }}"

      - name: Extract clean version
        run: |
          VERSION=${GITHUB_REF_NAME#v}
          echo "VERSION=$VERSION" >> $GITHUB_ENV

      - name: Restore dependencies
        run: dotnet restore {{ dotnet_solution }}

      - name: Build solution
        run: dotnet build {{ dotnet_solution }} --no-restore -c Release

      - name: Pack NuGet packages
        run: dotnet pack {{ dotnet_solution }} --no-build -c Release -o ./nupkg -p:PackageVersion=${{ env.VERSION }}

      - name: Upload package artifacts
        uses: actions/upload-artifact@043fb46d1a93c77aae656e7c1c64a875d1fc6a0a  # v7
        with:
          name: nuget-packages
          path: ./nupkg/*
          retention-days: 1

      - name: Publish to GitHub Packages
        run: |
          dotnet nuget push ./nupkg/*.nupkg \
            --api-key ${{ secrets.GITHUB_TOKEN }} \
            --source "https://nuget.pkg.github.com/${{ github.repository_owner }}/index.json" \
            --skip-duplicate

      - name: Extract release notes
        run: |
          VERSION=${GITHUB_REF_NAME#v}
          awk '/^## \['"${VERSION}"'\]/{flag=1; next} /^## \[/{if(flag) exit} flag' CHANGELOG.md > release_notes.md || true

      - name: Create GitHub Release
        uses: softprops/action-gh-release@b4309332981a82ec1c5618f44dd2e27cc8bfbfda  # v3
        with:
          body_path: release_notes.md
          files: ./nupkg/*
          generate_release_notes: true
          make_latest: true
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}

{% if use_semgrep %}
  # ──────────────────────────────────────────────────────────
  # Job 3: Security Scan (runs in parallel with build)
  # ──────────────────────────────────────────────────────────
  semgrep:
    name: Semgrep Security Scan
    runs-on: ubuntu-latest
    permissions:
      contents: read
      security-events: write
      pull-requests: write
      actions: read

    steps:
      - uses: actions/checkout@df4cb1c069e1874edd31b4311f1884172cec0e10  # v6
        with:
          fetch-depth: 0
          persist-credentials: false

      - name: Semgrep Scan
        id: semgrep
        uses: returntocorp/semgrep-action@713efdd345f3035192eaa63f56867b88e63e4e5d  # v1
        env:
          SEMGREP_RULES: p/auto p/secrets p/owasp-top-ten
        with:
          config: >-
            p/auto
            p/secrets
            p/owasp-top-ten

      - name: Upload SARIF to GitHub Security
        if: always()
        continue-on-error: true
        uses: github/codeql-action/upload-sarif@411bbbe57033eedfc1a82d68c01345aa96c737d7  # v4
        with:
          sarif_file: semgrep.sarif
          category: semgrep
{% endif %}
