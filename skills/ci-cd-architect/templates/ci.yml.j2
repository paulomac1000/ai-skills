# ci.yml — CI Pipeline
#
# This template is part of the CI/CD Architect standard (ci-cd-standard.md v2.1.0).
# It is designed to be processed by a Jinja2-compatible template engine.
#
# Substitution variables (from .github/ci-cd-config.yaml):
#   {{ src_dir }}        — e.g. "src/my_package/" or "tools/"
#   {{ package }}        — e.g. "my_package"
#   {{ project }}        — e.g. "my-project"
#   {{ python_version }} — e.g. "3.14"
#   {{ image_name }}     — e.g. "my-project:test"
#   {{ smoke_name }}     — e.g. "my-project-smoke"
#   {{ health_port }}    — e.g. "8080"
#   {{ is_mcp }}         — true/false
#   {{ expected_tools }} — e.g. 24 (only when is_mcp)
#   {{ rest_port }}      — e.g. "9096" (only when is_mcp)
#   {{ use_docker }}     — true/false
#   {{ services }}       — dict of {name: {image, ports}} or null
#   {{ language }}       — "python" | "dotnet" | "polyglot"

name: CI

on:
  push:
    branches: [main, master]
  pull_request:
  workflow_dispatch:

concurrency:
  group: ci-${{ github.ref }}
  cancel-in-progress: true

env:
  FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: true

jobs:
  lint:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@df4cb1c069e1874edd31b4311f1884172cec0e10  # v6
        with:
          persist-credentials: false

      - name: Set up Python
        uses: actions/setup-python@a309ff8b426b58ec0e2a45f0f869d46889d02405  # v6
        with:
          python-version: "{{ python_version }}"

      - name: Install dependencies and linting tools
        # --break-system-packages: required on Python ≥3.14 (PEP 668, externally managed environment)
        run: |
          python -m pip install --upgrade pip --break-system-packages
          pip install --break-system-packages -e ".[dev]"
          pip install --break-system-packages ruff mypy bandit

      - name: Ruff check
        run: ruff check .

      - name: Ruff format check
        run: ruff format --check .

      - name: mypy
        run: mypy {{ src_dir }} --strict

      - name: bandit
        run: bandit -r {{ src_dir }} -ll

      - name: Validate documentation (AFDS)
        if: hashFiles('afds_config.yaml') != ''
        run: |
          curl -sS https://raw.githubusercontent.com/paulomac1000/ai-skills/main/skills/afds-doc-writer/docs_validate.py | python3 - \
            --config afds_config.yaml --strict --baseline .afds-baseline.json ./

  test:
    runs-on: ubuntu-latest
    needs: lint
{% if services %}
    services:
{% for name, cfg in services.items() %}
      {{ name }}:
        image: {{ cfg.image }}
        ports:
{% for port in cfg.ports %}
          - {{ port }}
{% endfor %}
{% endfor %}
{% endif %}
    steps:
      - uses: actions/checkout@df4cb1c069e1874edd31b4311f1884172cec0e10  # v6
        with:
          persist-credentials: false

      - name: Set up Python {{ python_version }}
        uses: actions/setup-python@a309ff8b426b58ec0e2a45f0f869d46889d02405  # v6
        with:
          python-version: "{{ python_version }}"

      - name: Install dependencies
        # --break-system-packages: required on Python ≥3.14 (PEP 668, externally managed environment)
        run: |
          python -m pip install --upgrade pip --break-system-packages
          pip install --break-system-packages -e ".[dev]"

      - name: Run unit tests with coverage
        run: |
          pytest tests/unit/ -v --tb=short \
            --cov={{ package }} \
            --cov-report=term-missing \
            --cov-report=xml

{% if has_integration_tests %}
      - name: Run integration tests
        run: pytest tests/integration/ -v --tb=short
{% endif %}

      - name: Upload coverage to Codecov
        uses: codecov/codecov-action@e79a6962e0d4c0c17b229090214935d2e33f8354  # v6
        with:
          files: ./coverage.xml
          fail_ci_if_error: false
          token: ${{ secrets.CODECOV_TOKEN }}

{% if use_docker %}
  docker-smoke:
    runs-on: ubuntu-latest
    needs: test
{% if services %}
    services:
{% for name, cfg in services.items() %}
      {{ name }}:
        image: {{ cfg.image }}
        ports:
{% for port in cfg.ports %}
          - {{ port }}
{% endfor %}
{% endfor %}
{% endif %}
    steps:
      - uses: actions/checkout@df4cb1c069e1874edd31b4311f1884172cec0e10  # v6
        with:
          persist-credentials: false

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@d7f5e7f509e45cec5c76c4d5afdd7de93d0b3df5  # v4

      - name: Build Docker image
        uses: docker/build-push-action@f9f3042f7e2789586610d6e8b85c8f03e5195baf  # v7
        with:
          context: .
          load: true
          tags: {{ image_name }}
          cache-from: type=gha
          cache-to: type=gha,mode=max
{% if dockerfile_target %}
          target: {{ dockerfile_target }}
{% endif %}

{% if is_mcp %}
      # MUST update .github/ci-cd-config.yaml expected_tools when adding/removing tools
      - name: Smoke test — tool count
        run: |
          docker run --rm {{ image_name }} python3 -c "
          from server import get_tool_count
          tc = get_tool_count()
          assert tc == {{ expected_tools }}, f'Expected {{ expected_tools }} tools, got {tc}'
          print('Tool count OK:', tc)
          "

      - name: Smoke test — REST API health + tools
        run: |
          docker run -d --rm \
            -p {{ rest_port }}:{{ rest_port }} \
{% if services %}
            --network host \
{% endif %}
            -e MCP_UNSAFE_PUBLIC_ACCESS_CONFIRMED=1 \
            --name {{ smoke_name }} {{ image_name }}
          sleep 5
          curl -fsS --retry 10 --retry-delay 2 \
            http://localhost:{{ rest_port }}/api/health || exit 1
          TOOLS=$(curl -s http://localhost:{{ rest_port }}/api/tools \
            | python3 -c "import sys,json; d=json.load(sys.stdin); print(d['total'])")
          [ "$TOOLS" = "{{ expected_tools }}" ] \
            || (echo "FAIL: expected {{ expected_tools }}, got $TOOLS" && exit 1)
          docker stop {{ smoke_name }}
{% else %}
      - name: Smoke test — health check
        run: |
          docker run -d --rm \
            -p {{ health_port }}:{{ health_port }} \
{% if services %}
            --network host \
{% endif %}
            --name {{ smoke_name }} {{ image_name }}
          sleep 5
          curl -fsS --retry 10 --retry-delay 2 \
            http://localhost:{{ health_port }}/health || exit 1
          echo "Health check OK"
          docker stop {{ smoke_name }}
{% endif %}
{% else %}
  smoke:
    runs-on: ubuntu-latest
    needs: test
    steps:
      - uses: actions/checkout@df4cb1c069e1874edd31b4311f1884172cec0e10  # v6
        with:
          persist-credentials: false

      - name: Set up Python {{ python_version }}
        uses: actions/setup-python@a309ff8b426b58ec0e2a45f0f869d46889d02405  # v6
        with:
          python-version: "{{ python_version }}"

      - name: Install dependencies
        run: pip install --break-system-packages -e ".[dev]"

      - name: Run smoke tests
        run: pytest tests/smoke/ -v --tb=short
{% endif %}
